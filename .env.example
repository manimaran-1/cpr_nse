# === TELEGRAM CONFIGURATION ===
TELEGRAM_BOT_TOKEN=your_bot_token_from_BotFather
TELEGRAM_CHAT_ID=your_channel_or_group_chat_id

# === SCANNER CONFIGURATION ===
# Stock universe: "Nifty 50", "Nifty 200", "Nifty 500", "Total Cash Segment"
SCAN_UNIVERSE=Total Cash Segment

# Timeframe: "15m", "1h", "1d"
SCAN_INTERVAL=15m

# Send message even when no results found
SEND_IF_EMPTY=True

# === CPR CALCULATION METHOD ===
# Close method: "Intraday Candle Close", "Official Exchange LTP (Bhavcopy)", "Without Correction (Standard EOD Close)"
CLOSE_METHOD=Zerodha # Official Exchange LTP (Bhavcopy)

# Target session: "Current Session", "Next Session"
TARGET_SESSION=Next Session

# === DATA SOURCE ===
# "yahoo" (direct API, 1 req/symbol) or "yfinance" (library, 4+ req/symbol)
DATA_SOURCE=yahoo

# === OPTIONAL ===
# TEST_RUN=1        # Run scan immediately and exit
# ONCE=1            # Exit after one scan (no scheduling loop)
